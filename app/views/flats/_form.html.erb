<%= simple_form_for(flat) do |f| %>
  <%= f.input :name %>
  <%= f.input :address %>
  <%= f.input :description, as: :text, input_html: { rows: 4 } %>
  <div class="row">
    <div class="col"><%= f.input :price_per_night %></div>
    <div class="col"><%= f.input :number_of_guests %></div>
  </div>
  <div class="mt-4">
    <%= f.submit class: 'btn btn-primary' %>
    <%= link_to 'Cancel', flats_path, class: 'btn btn-danger' %>
  </div>
<% end %>
